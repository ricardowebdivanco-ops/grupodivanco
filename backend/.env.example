
# ====================================================
# DESARROLLO LOCAL
# ====================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=youruser
DB_PASSWORD=yourpassword
DB_NAME=yourdb

# ====================================================
# PRODUCCIÓN (Render)
# Render inyecta DATABASE_URL automáticamente si usas
# render.yaml. En producción sólo necesitas esta variable.
# ====================================================
# DATABASE_URL=postgresql://user:password@host:5432/dbname

NODE_ENV=production

# Control de sincronización de base de datos
# FORCE_SYNC=false  # Por defecto, preserva los datos existentes
# FORCE_SYNC=true   # Solo usar cuando necesites recrear todas las tablas (BORRARÁ TODOS LOS DATOS)

# JWT
JWT_SECRET=your_jwt_secret

# Nodemailer
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_email_password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# URL del frontend (Vercel)
FRONTEND_URL=https://divanco-web.vercel.app
